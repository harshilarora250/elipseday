# ---- Admin auth ----
# The username + password used to log into /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Secret used to sign the admin session cookie.
# Generate a long random string, e.g.:  openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string-please

# ---- Supabase (backend) ----
# The app reads data SERVER-SIDE. You can use EITHER naming convention
# (the code accepts both). The first set is preferred for full functionality
# (admin writes + uploads); the standard Supabase quickstart vars also work
# for public reads.

# Preferred (server-only secret — never expose the service_role key to the browser):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OR Supabase's standard quickstart vars (reads work via RLS; admin writes
# need the service_role key above):
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Storage bucket used for admin image uploads (create a PUBLIC bucket).
# Optional — defaults to "uploads".
SUPABASE_STORAGE_BUCKET=uploads

# Public site URL (used for Open Graph metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
