# ---- Admin auth ----
# The username + password used to log into /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Secret used to sign the admin session cookie.
# Generate a long random string, e.g.:  openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string-please

# ---- Supabase (backend) ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
# Supabase dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project.supabase.co

# SERVICE ROLE key (server-only secret — never expose to the browser).
# Supabase dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket used for admin image uploads (create a PUBLIC bucket).
# Optional — defaults to "uploads".
SUPABASE_STORAGE_BUCKET=uploads

# Public site URL (used for Open Graph metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
